<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Juniper Multi-Service Config Tool</title>
    <style>
        /* Premium Dashboard Design Tokens */
        :root[data-theme="light"] {
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --bg-input: #ffffff;
            --bg-accent: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --primary: #0284c7;
            --primary-glow: rgba(2, 132, 199, 0.2);
            --primary-hover: #0369a1;
            --tab-active-bg: #0284c7;
            --tab-active-text: #ffffff;
            --code-bg: #0f172a;
            --code-text: #38bdf8;
            --copy-btn-bg: #10b981;
            --copy-btn-hover: #059669;
        }

        :root[data-theme="dark"] {
            --bg-body: #0b0f19;
            --bg-card: #151d30;
            --bg-input: #0b0f19;
            --bg-accent: #1e2942;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border-color: #24304f;
            --primary: #38bdf8;
            --primary-glow: rgba(56, 189, 248, 0.25);
            --primary-hover: #7dd3fc;
            --tab-active-bg: #0284c7;
            --tab-active-text: #ffffff;
            --code-bg: #070b14;
            --code-text: #34d399;
            --copy-btn-bg: #10b981;
            --copy-btn-hover: #059669;
        }

        * {
            box-sizing: border-box;
            font-family: system-ui, -apple-system, sans-serif;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            transition: background-color 0.4s cubic-bezier(0.4, 0, 0.2, 1), color 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Top Header Navigation */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-card);
            padding: 15px 25px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            animation: slideDown 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .navbar h1 {
            font-size: 20px;
            font-weight: 700;
            margin: 0;
            background: linear-gradient(to right, #38bdf8, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .theme-btn {
            background: var(--bg-accent);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            cursor: pointer;
            border-radius: 20px;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.3s ease;
        }
        .theme-btn:hover {
            transform: scale(1.05);
            border-color: var(--primary);
        }

        /* Structural Cards with Entrance Animation */
        .card {
            background-color: var(--bg-card);
            border-radius: 12px;
            border: 1px solid var(--border-color);
            padding: 22px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
        }
        .card:nth-child(2) { animation-delay: 0.1s; }
        .card:nth-child(3) { animation-delay: 0.2s; }
        .card:nth-child(4) { animation-delay: 0.3s; }

        .section-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--primary);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px;
            position: relative;
        }
        
        /* Animated line under active header */
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 60px;
            height: 2px;
            background-color: var(--primary);
            animation: expandWidth 0.8s ease-out;
        }

        /* Custom Input Layouts */
        .grid-inputs {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 15px;
        }

        /* Service Cards Horizontal Grid */
        .services-grid-box {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 15px;
        }

        .service-row-card {
            background: var(--bg-accent);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 15px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .service-row-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            border-color: var(--primary);
        }

        .service-name-tag {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--text-main);
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 4px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-bottom: 10px;
        }

        .form-group:last-child {
            margin-bottom: 0;
        }

        label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Standardized High Quality Input Animations */
        input, textarea {
            width: 100%;
            padding: 8px 12px;
            background-color: var(--bg-input);
            color: var(--text-main);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            font-size: 13px;
            transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
        }

        input:focus, textarea:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 3px var(--primary-glow);
            transform: translateY(-1px);
        }

        textarea {
            resize: vertical;
            height: 75px;
            font-family: monospace;
        }

        /* Tabs Layout with micro-interactions */
        .tabs-header {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 12px;
        }

        .tab-button {
            background: var(--bg-accent);
            color: var(--text-muted);
            border: 1px solid var(--border-color);
            padding: 10px 20px;
            font-size: 13px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            white-space: nowrap;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .tab-button:hover {
            color: var(--text-main);
            background: var(--border-color);
        }

        .tab-button.active {
            background-color: var(--tab-active-bg);
            color: var(--tab-active-text);
            border-color: var(--tab-active-bg);
            transform: translateY(-1px);
        }

        .output-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 5px;
        }

        .status-indicator {
            font-size: 13px;
            font-weight: 600;
            color: #34d399;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: color 0.3s ease;
        }

        .copy-btn {
            background-color: var(--copy-btn-bg);
            color: #ffffff;
            border: none;
            padding: 8px 18px;
            font-size: 13px;
            font-weight: 700;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .copy-btn:hover {
            background-color: var(--copy-btn-hover);
            transform: scale(1.03);
        }
        .copy-btn:active {
            transform: scale(0.98);
        }

        /* High-Definition Raw Code Display with Active Viewport Fade-In */
        .code-container {
            position: relative;
            display: flex;
            flex-direction: column;
        }

        pre {
            background-color: var(--code-bg);
            color: var(--code-text);
            padding: 18px;
            border-radius: 8px;
            overflow: auto;
            font-family: 'Fira Code', 'Consolas', monospace;
            font-size: 13px;
            line-height: 1.6;
            margin: 0;
            min-height: 350px;
            max-height: 600px;
            border: 1px solid var(--border-color);
        }

        /* Tab Content Fade In Effect */
        .fade-in-effect {
            animation: codeFadeIn 0.35s ease-out;
        }

        /* --- STANDARD ANIMATION KEYFRAMES --- */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes expandWidth {
            from { width: 0; }
            to { width: 60px; }
        }

        @keyframes codeFadeIn {
            from {
                opacity: 0.6;
                transform: scale(0.995);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="navbar">
        <h1>Juniper Engine v2.5</h1>
        <button class="theme-btn" onclick="toggleTheme()" id="themeToggleBtn">☀️ Light Mode</button>
    </div>

    <div class="card">
        <h2 class="section-title">🌐 Global Nodes</h2>
        <div class="grid-inputs">
            <div class="form-group">
                <label>Interface</label>
                <input type="text" id="interface" value="ae0" oninput="generateAll()">
            </div>
            <div class="form-group">
                <label>PoP Location Suffix</label>
                <input type="text" id="pop_name" value="Narayanganj-Madanganj-PoP" oninput="generateAll()">
            </div>
            <div class="form-group">
                <label>Peer AS</label>
                <input type="number" id="peer_as" value="65008" oninput="generateAll()">
            </div>
            <div class="form-group">
                <label>Local AS</label>
                <input type="number" id="local_as" value="136141" oninput="generateAll()">
            </div>
            <div class="form-group">
                <label>Burst Limit</label>
                <input type="text" id="burst_limit" value="5m" oninput="generateAll()">
            </div>
        </div>
    </div>

    <div class="card">
        <h2 class="section-title">🛠️ Gateways & Service Vectors</h2>
        <div class="services-grid-box">
            <div class="service-row-card">
                <div class="service-name-tag">1. IIG Gateway</div>
                <div class="form-group"><label>Unit</label><input type="number" id="iig_unit" value="1751" oninput="generateAll()"></div>
                <div class="form-group"><label>Bandwidth</label><input type="text" id="iig_bw" value="140m" oninput="generateAll()"></div>
                <div class="form-group"><label>Logical Sys</label><input type="text" id="iig_ls" value="" placeholder="None" oninput="generateAll()"></div>
                <div class="form-group"><label>Neighbor IP</label><input type="text" id="iig_neighbor" value="10.1.155.58" oninput="generateAll()"></div>
            </div>
            <div class="service-row-card">
                <div class="service-name-tag">2. GGC Gateway</div>
                <div class="form-group"><label>Unit</label><input type="number" id="ggc_unit" value="1752" oninput="generateAll()"></div>
                <div class="form-group"><label>Bandwidth</label><input type="text" id="ggc_bw" value="900m" oninput="generateAll()"></div>
                <div class="form-group"><label>Logical Sys</label><input type="text" id="ggc_ls" value="GGC-R1" oninput="generateAll()"></div>
                <div class="form-group"><label>Neighbor IP</label><input type="text" id="ggc_neighbor" value="10.2.155.58" oninput="generateAll()"></div>
            </div>
            <div class="service-row-card">
                <div class="service-name-tag">3. FNA Gateway</div>
                <div class="form-group"><label>Unit</label><input type="number" id="fna_unit" value="1753" oninput="generateAll()"></div>
                <div class="form-group"><label>Bandwidth</label><input type="text" id="fna_bw" value="550m" oninput="generateAll()"></div>
                <div class="form-group"><label>Logical Sys</label><input type="text" id="fna_ls" value="FNA-R1" oninput="generateAll()"></div>
                <div class="form-group"><label>Neighbor IP</label><input type="text" id="fna_neighbor" value="10.3.155.58" oninput="generateAll()"></div>
            </div>
            <div class="service-row-card">
                <div class="service-name-tag">4. BDIX Gateway</div>
                <div class="form-group"><label>Unit</label><input type="number" id="bdix_unit" value="1754" oninput="generateAll()"></div>
                <div class="form-group"><label>Bandwidth</label><input type="text" id="bdix_bw" value="570m" oninput="generateAll()"></div>
                <div class="form-group"><label>Logical Sys</label><input type="text" id="bdix_ls" value="BDIX-R1" oninput="generateAll()"></div>
                <div class="form-group"><label>Neighbor IP</label><input type="text" id="bdix_neighbor" value="10.4.155.58" oninput="generateAll()"></div>
            </div>
            <div class="service-row-card">
                <div class="service-name-tag">5. CDN Gateway</div>
                <div class="form-group"><label>Unit</label><input type="number" id="cdn_unit" value="1755" oninput="generateAll()"></div>
                <div class="form-group"><label>Bandwidth</label><input type="text" id="cdn_bw" value="40m" oninput="generateAll()"></div>
                <div class="form-group"><label>Logical Sys</label><input type="text" id="cdn_ls" value="CDN-R1" oninput="generateAll()"></div>
                <div class="form-group"><label>Neighbor IP</label><input type="text" id="cdn_neighbor" value="10.5.155.58" oninput="generateAll()"></div>
            </div>
        </div>

        <div class="form-group" style="margin-top: 5px;">
            <label>Route Filter Injections</label>
            <textarea id="routes" oninput="generateAll()">103.137.66.48/30 exact
103.13.192.182/31 exact
121.200.221.126/31 exact</textarea>
        </div>
    </div>

    <div class="card">
        <div class="tabs-header">
            <button class="tab-button active" onclick="switchTab('IIG')">IIG Config</button>
            <button class="tab-button" onclick="switchTab('GGC')">GGC Config</button>
            <button class="tab-button" onclick="switchTab('FNA')">FNA Config</button>
            <button class="tab-button" onclick="switchTab('BDIX')">BDIX Config</button>
            <button class="tab-button" onclick="switchTab('CDN')">CDN Config</button>
        </div>

        <div class="output-meta">
            <div class="status-indicator" id="activeProfileLabel">● IIG Raw Commands (Standard Context):</div>
            <button class="copy-btn" onclick="copyCurrentTab()">Copy Code</button>
        </div>

        <div class="code-container">
            <pre id="output">Compiling micro-scripts...</pre>
        </div>
    </div>
</div>

<script>
    let activeServiceTab = 'IIG';
    const storageCache = {};

    function toggleTheme() {
        const root = document.documentElement;
        const currentTheme = root.getAttribute('data-theme');
        const btn = document.getElementById('themeToggleBtn');
        if (currentTheme === 'dark') {
            root.setAttribute('data-theme', 'light');
            btn.textContent = "🌙 Dark Mode";
        } else {
            root.setAttribute('data-theme', 'dark');
            btn.textContent = "☀️ Light Mode";
        }
    }

    function switchTab(serviceName) {
        activeServiceTab = serviceName;
        
        // Tab UI button highlight reset
        const buttons = document.querySelectorAll('.tab-button');
        buttons.forEach(btn => {
            if(btn.textContent.startsWith(serviceName)) {
                btn.classList.add('active');
            } else {
                btn.classList.remove('active');
            }
        });

        // Update Label dynamically based on presence of logical-system
        const lsValue = document.getElementById(`${serviceName.toLowerCase()}_ls`).value.trim();
        const label = document.getElementById('activeProfileLabel');
        if(lsValue) {
            label.textContent = `● ${serviceName} Raw Commands (Logical System):`;
            label.style.color = '#34d399';
        } else {
            label.textContent = `● ${serviceName} Raw Commands (Standard Context):`;
            label.style.color = '#38bdf8';
        }

        // Project cached generated text with subtle fade-in animation
        const outputField = document.getElementById('output');
        outputField.textContent = storageCache[serviceName] || '';
        
        // Reset and trigger smooth code reload animation
        outputField.classList.remove('fade-in-effect');
        void outputField.offsetWidth; // Trigger reflow
        outputField.classList.add('fade-in-effect');
    }

    function generateAll() {
        const intf = document.getElementById('interface').value.trim();
        const pop = document.getElementById('pop_name').value.trim();
        const peerAs = document.getElementById('peer_as').value.trim();
        const localAs = document.getElementById('local_as').value.trim();
        const burst = document.getElementById('burst_limit').value.trim();
        const routesText = document.getElementById('routes').value.trim();
        const routesArray = routesText.split('\n').map(r => r.trim()).filter(r => r.length > 0);

        const configurationsMap = [
            { key: 'IIG', unit: 'iig_unit', bw: 'iig_bw', ls: 'iig_ls', ip: 'iig_neighbor', exp: 'FOR-DEFAULT-ROUTE-EXPORT', comm: 'IIG-BGP-CLIENTS-IMPORT' },
            { key: 'GGC', unit: 'ggc_unit', bw: 'ggc_bw', ls: 'ggc_ls', ip: 'ggc_neighbor', exp: 'FOR-EBGP-GGC-CLIENTS-EXPORT', comm: 'GGC-BGP-CLIENTS-IMPORT' },
            { key: 'FNA', unit: 'fna_unit', bw: 'fna_bw', ls: 'fna_ls', ip: 'fna_neighbor', exp: 'FOR-EBGP-FNA-CLIENTS-EXPORT', comm: 'FNA-BGP-CLIENTS-IMPORT' },
            { key: 'BDIX', unit: 'bdix_unit', bw: 'bdix_bw', ls: 'bdix_ls', ip: 'bdix_neighbor', exp: 'FOR-EBGP-BDIX-CLIENTS-EXPORT', comm: 'BDIX-BGP-CLIENTS-IMPORT' },
            { key: 'CDN', unit: 'cdn_unit', bw: 'cdn_bw', ls: 'cdn_ls', ip: 'cdn_neighbor', exp: 'FOR-EBGP-CDN-CLIENTS-EXPORT', comm: 'CDN-BGP-CLIENTS-IMPORT' }
        ];

        configurationsMap.forEach(item => {
            const u = document.getElementById(item.unit).value.trim();
            const b = document.getElementById(item.bw).value.trim();
            const l = document.getElementById(item.ls).value.trim();
            const neighborIP = document.getElementById(item.ip).value.trim();
            
            const desc = `${pop}-${item.key}`;
            const prefix = l ? `set logical-systems ${l} ` : `set `;
            
            let block = '';
            block += `${prefix}interfaces ${intf} unit ${u} description ${desc}\n`;
            block += `${prefix}interfaces ${intf} unit ${u} family inet policer output ${desc}\n`;
            
            block += `${prefix}protocols bgp group ${desc} type external\n`;
            block += `${prefix}protocols bgp group ${desc} import ${desc}-IMPORT\n`;
            block += `${prefix}protocols bgp group ${desc} export ${item.exp}\n`;
            block += `${prefix}protocols bgp group ${desc} peer-as ${peerAs}\n`;
            block += `${prefix}protocols bgp group ${desc} local-as ${localAs}\n`;
            block += `${prefix}protocols bgp group ${desc} neighbor ${neighborIP}\n`;

            routesArray.forEach(route => {
                block += `${prefix}policy-options policy-statement ${desc}-IMPORT term 1 from route-filter ${route}\n`;
            });
            block += `${prefix}policy-options policy-statement ${desc}-IMPORT term 1 then community add ${item.comm}\n`;
            block += `${prefix}policy-options policy-statement ${desc}-IMPORT term 1 then accept\n`;
            block += `${prefix}policy-options policy-statement ${desc}-IMPORT term 100 then reject\n`;

            block += `set firewall policer ${desc} if-exceeding bandwidth-limit ${b}\n`;
            block += `set firewall policer ${desc} if-exceeding burst-size-limit ${burst}\n`;
            block += `set firewall policer ${desc} then discard\n`;

            storageCache[item.key] = block;
        });

        // Update the current viewport safely without killing user sight position
        document.getElementById('output').textContent = storageCache[activeServiceTab] || '';
    }

    function copyCurrentTab() {
        const activeText = storageCache[activeServiceTab];
        if(!activeText) return;
        navigator.clipboard.writeText(activeText).then(() => {
            alert(`${activeServiceTab} config successfully copied!`);
        });
    }

    window.onload = generateAll;
</script>

</body>
</html>
